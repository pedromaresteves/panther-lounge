<div class="mb-3">
  <label for="<%= inputId %>" class="form-label"><%= label %></label>
  <input 
    type="<%= typeof type !== 'undefined' ? type : 'text' %>" 
    class="form-control" 
    name="<%= name %>" 
    id="<%= inputId %>"
    placeholder="<%= typeof placeholder !== 'undefined' ? placeholder : '' %>"
    <% if (typeof required !== 'undefined' && required) { %>required<% } %>
    <% if (typeof minlength !== 'undefined' && minlength) { %>minlength="<%= minlength %>"<% } %>
    <% if (typeof maxlength !== 'undefined' && maxlength) { %>maxlength="<%= maxlength %>"<% } %>
    <% if (typeof value !== 'undefined' && value) { %>value="<%= value %>"<% } %>
  >
</div>
