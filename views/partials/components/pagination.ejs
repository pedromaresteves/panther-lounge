<nav id="pag-nav" class="mt-3" aria-label="Page navigation">
  <ul class="pagination justify-content-center">
    <% for(let i = 1; i <= (typeof pageCount !== 'undefined' ? pageCount : 2); i++) {%>
      <li class="page-item">
        <a class="page-link" href="#"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
