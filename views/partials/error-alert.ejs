<% if (typeof errorMessage !== 'undefined' || typeof loginError !== 'undefined' || (typeof fail !== 'undefined' && fail && fail.failedMsg)) { %>
  <div class="alert alert-danger alert-dismissible fade show container mt-3" role="alert">
    <strong>Error:</strong> <%= errorMessage || loginError || (fail && fail.failedMsg) %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
