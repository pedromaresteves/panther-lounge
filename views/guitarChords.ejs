<div class="container">
  <div class="row">
    <div class="mt-1 col-md-8 offset-md-2 mb-3">
      <div>
        <input id="search-input" type="text" class="form-control" placeholder="Search for your favorite artist" aria-label="Insert Artist or Song" aria-describedby="basic-addon1">
        <div class="border" id="search-results">
          <ul id="artist-list" class="list-group"></ul>
          <ul id="song-list" class="list-group"></ul>
        </div>
      </div>
    </div>
  </div>
  <%if(userData){%>
    <%- include('./partials/components/add-song-button') %>
  <%} else {%>
    <%- include('./partials/components/login-prompt') %>
  <%}%>
  <div class='row'>    
    <div class='col-md-10 offset-md-1'>
      <h4 class='text-center mt-3'>Choose your favorite artist</h4>
      <ul id="page-results" class="list-group">
        <%- include('./partials/components/spinner') %>
      </ul>
      <%- include('./partials/components/pagination') %>
    </div>
  </div>
</div>