<!doctype html>  
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Panther's Lounge</title>
    <link rel="icon" href="/assets/cat-solid.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel='stylesheet' href='https://cdn.bootcss.com/bootstrap-social/5.1.1/bootstrap-social.min.css'>
     <link rel="stylesheet" href="/css/style.css">
     <link rel="stylesheet" href="/css/tooltip.css">
     <script>
       (function() {
         const savedTheme = localStorage.getItem('theme');
         if (savedTheme === 'dark') {
           document.documentElement.setAttribute('data-theme', 'dark');
         }
       })();
     </script>
     <script src="https://kit.fontawesome.com/b98331d97a.js" defer></script>
      <!-- Standalone chord tooltip (immediate fallback) -->
    <script src="/js/chordTooltipStandalone.js" defer></script>
    <!-- Main application module (includes VexChords from npm) -->
    <script type="module" src="/js/main.bundle.js" defer></script>
    <!-- Debug script to verify everything loaded -->
    <script>
      console.log('Page scripts loaded');
      document.addEventListener('DOMContentLoaded', function() {
        console.log('DOM fully loaded, checking components:', {
          chordTooltipAvailable: typeof window.chordTooltip !== 'undefined',
          vexChordsAvailable: typeof window.VexChords !== 'undefined'
        });
      });
    </script>
  </head>

  <body>
    <%- include('../partials/navbar') %>
    
    <main class="mb-5">
      <%- include('../partials/error-alert') %>
      <%- body %>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
